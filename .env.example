# ---------------------------------------------------------------------------
# Redpanda Serverless connection (Kafka API)
# Find these in Redpanda Cloud Console -> your cluster -> "Kafka API" / "Security"
# ---------------------------------------------------------------------------

# Bootstrap server, e.g. seed-xxxxxxxx.xxx.byoc.prd.cloud.redpanda.com:9092
REDPANDA_BROKERS=

# SASL user you create under Cluster -> Security -> Users
REDPANDA_USERNAME=
REDPANDA_PASSWORD=

# Redpanda Serverless uses SCRAM-SHA-256 by default
REDPANDA_SASL_MECHANISM=SCRAM-SHA-256

# Topic the producer writes to (and ClickPipes reads from)
REDPANDA_TOPIC=clickstream_events

# ---------------------------------------------------------------------------
# Producer tuning (optional)
# ---------------------------------------------------------------------------
# Total number of events to send (0 = run forever)
EVENT_COUNT=100000
# Approximate events per second
EVENTS_PER_SECOND=200
